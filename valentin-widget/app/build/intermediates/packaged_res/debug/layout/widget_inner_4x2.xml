<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="horizontal" android:gravity="center" android:padding="10dp"
    android:background="@drawable/widget_bg_rounded">
    <TextView android:id="@+id/widget_emoji"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="💕" android:textSize="50sp"
        android:shadowColor="#99000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="4"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:gravity="center_vertical" android:paddingStart="10dp">
        <TextView android:id="@+id/widget_sender"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="" android:textColor="#ddffffff" android:textSize="11sp"
            android:shadowColor="#99000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="3"/>
        <TextView android:id="@+id/widget_label"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Esperando..." android:textColor="#ffffff" android:textSize="18sp"
            android:textStyle="bold" android:layout_marginTop="2dp"
            android:shadowColor="#99000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="4"/>
        <TextView android:id="@+id/widget_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="" android:textColor="#ccffffff" android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:shadowColor="#99000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="3"/>
    </LinearLayout>
</LinearLayout>
